# SalesPilot CRM backend
# Copy this file to `backend/.env` for local development.

# App
APP_NAME=SalesPilot CRM
APP_ENV=development

# Database
DATABASE_URL=mysql+aiomysql://salespilot:changeme123@127.0.0.1:3306/salespilot_db
DATABASE_SYNC_URL=mysql+pymysql://salespilot:changeme123@127.0.0.1:3306/salespilot_db

# Security
SECRET_KEY=change-this-in-development-too
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# AI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# DashScope / Paraformer
DASHSCOPE_API_KEY=your-dashscope-api-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
PARAFORMER_MODEL=paraformer-v2
PARAFORMER_LANGUAGE_HINTS=["zh","en"]

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173","http://localhost:5500","http://127.0.0.1:5500","http://localhost:5501","http://127.0.0.1:5501","http://localhost:8080","http://127.0.0.1:8080"]
